{%- comment -%}
  EzHome — Gift Card Template
  Note: gift_card.liquid must be a Liquid template, not JSON
{%- endcomment -%}

<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ 'gift_cards.issued.title' | t }} — {{ shop.name }}</title>
  {{ 'base.css' | asset_url | stylesheet_tag }}
  <style>
    .gift-card { max-width: 520px; margin: var(--space-12) auto; padding: var(--space-8); text-align: center; }
    .gift-card__image { max-width: 100%; border-radius: var(--radius-lg); margin-bottom: var(--space-6); }
    .gift-card__code { font-family: monospace; font-size: var(--text-heading-xl); letter-spacing: 0.1em; padding: var(--space-3); background: var(--bg-secondary); border-radius: var(--radius-md); margin: var(--space-4) 0; display: inline-block; }
    .gift-card__balance { font-size: var(--text-display-lg); font-weight: var(--weight-bold); color: var(--color-sage-600); }
    .gift-card__qr { margin: var(--space-6) auto; }
    .gift-card__shop { margin-top: var(--space-6); }
  </style>
  {{ content_for_header }}
</head>
<body>
  <div class="gift-card">
    <h1 class="text-heading-2xl" style="margin-bottom: var(--space-2);">{{ shop.name }}</h1>
    <p class="text-body-lg color-secondary" style="margin-bottom: var(--space-6);">{{ 'gift_cards.issued.subtext' | t }}</p>

    {%- if gift_card.image -%}
      <img src="{{ gift_card | img_url: '600x' }}" alt="" class="gift-card__image">
    {%- endif -%}

    <div class="gift-card__balance">{{ gift_card.balance | money }}</div>

    {%- if gift_card.balance != gift_card.initial_value -%}
      <p class="text-body-sm color-secondary">Initial value: {{ gift_card.initial_value | money }}</p>
    {%- endif -%}

    <div class="gift-card__code" id="gift-card-code">{{ gift_card.code | format_code }}</div>

    {%- if gift_card.pass_url -%}
      <a href="{{ gift_card.pass_url }}" class="btn btn--ghost btn--sm" style="margin-top: var(--space-2);">
        {{ 'gift_cards.issued.add_to_apple_wallet' | t }}
      </a>
    {%- endif -%}

    <div class="gift-card__qr">
      {%- assign qr_url = gift_card.qr_identifier | prepend: 'web+shopify://qr/' -%}
      <img src="https://chart.googleapis.com/chart?chs=200x200&cht=qr&chl={{ qr_url | url_encode }}" alt="QR Code" width="200" height="200">
    </div>

    {%- if gift_card.expired -%}
      <p class="text-body-md" style="color: var(--color-red-600);">{{ 'gift_cards.issued.expired' | t }}</p>
    {%- elsif gift_card.enabled -%}
      {%- if gift_card.expires_on -%}
        <p class="text-body-sm color-secondary">{{ 'gift_cards.issued.expiration_date' | t: expires_on: gift_card.expires_on | date: '%B %d, %Y' }}</p>
      {%- endif -%}
    {%- else -%}
      <p class="text-body-md" style="color: var(--color-red-600);">{{ 'gift_cards.issued.disabled' | t }}</p>
    {%- endif -%}

    <div class="gift-card__shop">
      <a href="{{ shop.url }}" class="btn btn--primary" target="_blank">{{ 'gift_cards.issued.shop_link' | t }}</a>
    </div>

    <button class="btn btn--ghost btn--sm" style="margin-top: var(--space-3);" onclick="
      var code = document.getElementById('gift-card-code');
      var range = document.createRange();
      range.selectNode(code);
      window.getSelection().removeAllRanges();
      window.getSelection().addRange(range);
      document.execCommand('copy');
      this.textContent = 'Copied!';
      setTimeout(function(){ this.textContent = 'Copy Code'; }.bind(this), 2000);
    ">Copy Code</button>
  </div>
</body>
</html>
