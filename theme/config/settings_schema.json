      {
        "type": "text",
        "id": "trust_assembly_text",
        "label": "Assembly Trust Text",
        "default": "10-Min Assembly"
      },
      {
        "type": "text",
        "id": "trust_warranty_text",
        "label": "Warranty Trust Text",
        "default": "5-Year Warranty"
      },
      {
        "type": "text",
        "id": "trust_trial_text",
        "label": "Trial Trust Text",
        "default": "100-Night Trial"
      }
