{%- comment -%}
  Renders a responsive image with srcset, sizes, and lazy loading.

  Usage:
    {% render 'responsive-image', image: product.featured_image, alt: product.title, sizes: '(min-width: 1024px) 33vw, 50vw', aspect_ratio: '1/1', class: 'card__image' %}

  Parameters:
    - image: Shopify image object
    - alt: Alt text string
    - sizes: Sizes attribute string
    - aspect_ratio: CSS aspect-ratio value (e.g., '1/1', '3/4')
    - class: Additional CSS classes
    - lazy: Boolean, default true
    - width: Max width for srcset generation
    - preload: Boolean for high-priority images
{%- endcomment -%}

{%- liquid
  assign lazy = lazy | default: true
  assign width = width | default: 1200
  assign preload = preload | default: false
-%}

{%- if image != blank -%}
  <img
    src="{{ image | image_url: width: width }}"
    srcset="
      {%- if image.width >= 375 -%}{{ image | image_url: width: 375 }} 375w,{%- endif -%}
      {%- if image.width >= 550 -%}{{ image | image_url: width: 550 }} 550w,{%- endif -%}
      {%- if image.width >= 750 -%}{{ image | image_url: width: 750 }} 750w,{%- endif -%}
      {%- if image.width >= 1100 -%}{{ image | image_url: width: 1100 }} 1100w,{%- endif -%}
      {%- if image.width >= 1500 -%}{{ image | image_url: width: 1500 }} 1500w,{%- endif -%}
      {{ image | image_url }} {{ image.width }}w
    "
    {% if sizes %}sizes="{{ sizes }}"{% endif %}
    alt="{{ alt | escape }}"
    width="{{ image.width }}"
    height="{{ image.height }}"
    {% if lazy and preload == false %}loading="lazy" decoding="async"{% else %}loading="eager" fetchpriority="high"{% endif %}
    {% if class %}class="{{ class }}"{% endif %}
    {% if aspect_ratio %}style="aspect-ratio: {{ aspect_ratio }}; object-fit: cover;"{% endif %}
  >
{%- else -%}
  <div class="placeholder-image {{ class }}" {% if aspect_ratio %}style="aspect-ratio: {{ aspect_ratio }};"{% endif %}>
    {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
  </div>
{%- endif -%}
