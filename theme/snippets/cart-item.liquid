{%- comment -%}
  Renders cart line item.

  Usage:
    {% render 'cart-item', item: item %}

  Parameters:
    - item: Shopify cart line item object
{%- endcomment -%}

<div class="cart-item" data-cart-item data-key="{{ item.key }}">
  <a href="{{ item.url }}" class="cart-item__image-link">
    <div class="cart-item__image media media--square">
      {%- if item.image != blank -%}
        {%- render 'responsive-image',
          image: item.image,
          alt: item.title,
          sizes: '80px',
          width: 160,
          class: 'cart-item__img'
        -%}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>
  </a>

  <div class="cart-item__details">
    <div class="cart-item__header">
      <div class="cart-item__info">
        <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>

        {%- unless item.product.has_only_default_variant -%}
          <p class="cart-item__variant text-body-sm color-secondary">
            {{ item.variant.title }}
          </p>
        {%- endunless -%}

        {%- if item.selling_plan_allocation -%}
          <p class="cart-item__plan text-body-sm color-secondary">
            {{ item.selling_plan_allocation.selling_plan.name }}
          </p>
        {%- endif -%}
      </div>

      <button
        type="button"
        class="cart-item__remove"
        data-cart-remove
        data-key="{{ item.key }}"
        aria-label="{{ 'cart.remove' | t }}"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M13.5 4.5l-9 9M4.5 4.5l9 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <div class="cart-item__footer">
      <div class="cart-item__quantity" data-quantity-selector>
        <button
          type="button"
          class="cart-item__qty-btn"
          data-quantity-minus
          data-key="{{ item.key }}"
          aria-label="{{ 'product.quantity.decrease' | t }}"
        >
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M3 7h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
        <input
          type="number"
          class="cart-item__qty-input"
          data-quantity-input
          data-key="{{ item.key }}"
          value="{{ item.quantity }}"
          min="0"
          max="{{ item.variant.inventory_quantity | default: 99 }}"
          aria-label="{{ 'product.quantity.label' | t }}"
        >
        <button
          type="button"
          class="cart-item__qty-btn"
          data-quantity-plus
          data-key="{{ item.key }}"
          aria-label="{{ 'product.quantity.increase' | t }}"
        >
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M7 3v8M3 7h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </div>

      <span class="cart-item__line-price" data-cart-item-price>
        {{ item.final_line_price | money }}
      </span>
    </div>

    {%- if item.original_line_price != item.final_line_price -%}
      <div class="cart-item__discounts text-body-sm">
        {%- for discount in item.line_level_discount_allocations -%}
          <span class="cart-item__discount color-accent">
            {{ discount.discount_application.title }} (-{{ discount.amount | money }})
          </span>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .cart-item {
    display: flex;
    gap: var(--space-4);
    padding-block: var(--space-4);
    border-bottom: 1px solid var(--border-secondary);
  }

  .cart-item:last-child {
    border-bottom: none;
  }

  .cart-item__image-link {
    flex-shrink: 0;
  }

  .cart-item__image {
    width: 80px;
    height: 80px;
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .cart-item__details {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cart-item__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-2);
  }

  .cart-item__title {
    font-weight: var(--weight-medium);
    font-size: var(--text-body-md);
    text-decoration: none;
    color: var(--text-primary);
  }

  .cart-item__title:hover {
    color: var(--text-link-hover);
  }

  .cart-item__remove {
    flex-shrink: 0;
    color: var(--text-tertiary);
    padding: var(--space-1);
    transition: color var(--duration-fast) var(--ease-default);
  }

  .cart-item__remove:hover {
    color: var(--status-error);
  }

  .cart-item__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .cart-item__quantity {
    display: flex;
    align-items: center;
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .cart-item__qty-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    color: var(--text-secondary);
    transition: background-color var(--duration-fast) var(--ease-default);
  }

  .cart-item__qty-btn:hover {
    background-color: var(--bg-secondary);
    color: var(--text-primary);
  }

  .cart-item__qty-input {
    width: 36px;
    height: 32px;
    border: none;
    text-align: center;
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    background: transparent;
    -moz-appearance: textfield;
  }

  .cart-item__qty-input::-webkit-inner-spin-button,
  .cart-item__qty-input::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .cart-item__line-price {
    font-weight: var(--weight-semibold);
    font-size: var(--text-body-md);
  }

  .cart-item__discounts {
    display: flex;
    flex-direction: column;
    gap: var(--space-0-5);
  }
</style>
