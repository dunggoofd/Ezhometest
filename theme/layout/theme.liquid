<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}" dir="{{ request.locale.text_direction_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="{{ settings.color_primary }}">

  <title>
    {%- if page_title == blank -%}{{ shop.name }}
    {%- elsif template.name == 'index' -%}{{ page_title }}
    {%- else -%}{{ page_title }} — {{ shop.name }}
    {%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {%- render 'meta-tags' -%}
  {%- render 'json-ld' -%}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
  {%- endif -%}

  {%- comment -%} Fonts loaded via Shopify font_picker in settings {%- endcomment -%}

  {%- comment -%} CSS {%- endcomment -%}
  {{ 'base.css' | asset_url | stylesheet_tag: preload: true }}

  {%- comment -%} Preconnect to Shopify CDN {%- endcomment -%}
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

  {{ content_for_header }}

  <script>
    document.documentElement.classList.replace('no-js', 'js');

    window.EzHome = window.EzHome || {};
    window.EzHome.routes = {
      cart_url: '{{ routes.cart_url }}',
      cart_add_url: '{{ routes.cart_add_url }}',
      cart_change_url: '{{ routes.cart_change_url }}',
      cart_update_url: '{{ routes.cart_update_url }}',
      search_url: '{{ routes.search_url }}',
      predictive_search_url: '{{ routes.predictive_search_url }}'
    };
    window.EzHome.moneyFormat = {{ shop.money_format | json }};
    window.EzHome.cartType = {{ settings.cart_type | json }};
    window.EzHome.freeShippingThreshold = {{ settings.cart_free_shipping_threshold | default: '15000' | json }};
  </script>
</head>

<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">
  <a href="#main" class="skip-to-content visually-hidden">
    {{ 'general.skip_to_content' | t }}
  </a>

  {%- sections 'header-group' -%}

  {%- section 'cart-drawer' -%}

  <main id="main" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- sections 'footer-group' -%}

  {%- comment -%} Global JS — deferred {%- endcomment -%}
  <script src="{{ 'global.js' | asset_url }}" defer></script>

  {%- comment -%} Scroll animations {%- endcomment -%}
  <script src="{{ 'scroll-animations.js' | asset_url }}" defer></script>
</body>
</html>
