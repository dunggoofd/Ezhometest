{%- comment -%}
  EzHome — Testimonials Carousel Section
  Customer reviews with social proof header + stats
{%- endcomment -%}

<div class="testimonials section-spacing" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="testimonials__header reveal">
      {%- if section.settings.eyebrow != blank -%}
        <span class="text-overline color-accent">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="text-heading-xl">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    {%- comment -%} Stats bar {%- endcomment -%}
    {%- if section.settings.show_stats -%}
      <div class="testimonials__stats reveal" style="--reveal-delay: 1;">
        <div class="testimonials__stat">
          <span class="testimonials__stat-number text-display-sm">2,400+</span>
          <span class="testimonials__stat-label text-body-sm color-secondary">sofas delivered to apartments</span>
        </div>
        <div class="testimonials__stat">
          <span class="testimonials__stat-number text-display-sm">4.9 ★</span>
          <span class="testimonials__stat-label text-body-sm color-secondary">average review (1,200+ ratings)</span>
        </div>
        <div class="testimonials__stat">
          <span class="testimonials__stat-number text-display-sm">&lt;5 min</span>
          <span class="testimonials__stat-label text-body-sm color-secondary">doorway-to-done setup time</span>
        </div>
        <div class="testimonials__stat">
          <span class="testimonials__stat-number text-display-sm">96%</span>
          <span class="testimonials__stat-label text-body-sm color-secondary">say "easier than any sofa move"</span>
        </div>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="testimonials__grid reveal" style="--reveal-delay: 2;">
        {%- for block in section.blocks -%}
          <div class="testimonial-card" {{ block.shopify_attributes }}>
            <div class="testimonial-card__rating">
              {%- render 'star-rating', rating: block.settings.rating -%}
            </div>
            <blockquote class="testimonial-card__quote text-body-md">
              "{{ block.settings.quote }}"
            </blockquote>
            <div class="testimonial-card__author">
              <span class="testimonial-card__name text-body-md" style="font-weight: var(--weight-semibold);">{{ block.settings.author }}</span>
              {%- if block.settings.detail != blank -%}
                <span class="testimonial-card__detail text-body-sm color-secondary">{{ block.settings.detail }}</span>
              {%- endif -%}
            </div>
            <span class="testimonial-card__badge">Verified Buyer</span>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .testimonials__header {
    text-align: center;
    margin-bottom: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .testimonials__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
    margin-bottom: var(--space-10);
    padding: var(--space-8) 0;
    border-top: 1px solid var(--border-secondary);
    border-bottom: 1px solid var(--border-secondary);
  }

  .testimonials__stat {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .testimonials__stat-number {
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .testimonial-card {
    background-color: var(--bg-primary);
    border: 1px solid var(--border-secondary);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .testimonial-card__quote {
    margin: 0;
    font-style: italic;
    flex: 1;
  }

  .testimonial-card__author {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .testimonial-card__badge {
    display: inline-flex;
    align-self: flex-start;
    padding: var(--space-1) var(--space-2);
    background-color: var(--color-sage-50);
    color: var(--color-sage-700);
    font-size: 11px;
    font-weight: var(--weight-semibold);
    border-radius: var(--radius-sm);
    letter-spacing: 0.02em;
  }

  @media (max-width: 1024px) {
    .testimonials__stats {
      grid-template-columns: repeat(2, 1fr);
    }

    .testimonials__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .testimonials__stats {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-4);
      padding: var(--space-5) 0;
    }

    .testimonials__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section--testimonials",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "DON'T TAKE OUR WORD FOR IT"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "2,400+ apartments. Zero sofas stuck in lobbies."
    },
    {
      "type": "checkbox",
      "id": "show_stats",
      "label": "Show stats bar",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "limit": 6,
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "We live on the 4th floor, no lift. Two of us carried it upstairs in the box. I still can't believe it expanded into THIS."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Sam & Jess T."
        },
        {
          "type": "text",
          "id": "detail",
          "label": "Detail (city, product)",
          "default": "Melbourne · 2-seater in Charcoal"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "category": "EzHome",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "We live on the 4th floor, no lift. Two of us carried it upstairs in the box. I still can't believe it expanded into THIS.",
            "author": "Sam & Jess T.",
            "detail": "Melbourne · 2-seater in Charcoal",
            "rating": 5
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "Third apartment in two years. This sofa has moved with me every time — no removalists, no scratched walls, no stress.",
            "author": "David K.",
            "detail": "Sydney · 3-seater L-shape in Oat",
            "rating": 5
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "Honestly looks more expensive than it is. Guests always ask where it's from. The washable covers are a game-changer with kids.",
            "author": "Michelle L.",
            "detail": "Brisbane · Modular 4-piece in Sage",
            "rating": 5
          }
        }
      ]
    }
  ]
}
{% endschema %}
