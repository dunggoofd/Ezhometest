{%- comment -%}
  EzHome — Main Blog Section
  Blog article grid
{%- endcomment -%}

<div class="main-blog section-spacing" data-section-id="{{ section.id }}">
  <div class="page-width">
    {%- paginate blog.articles by section.settings.articles_per_page -%}
      <div class="main-blog__grid grid grid--{{ section.settings.columns }}">
        {%- for article in blog.articles -%}
          <article class="blog-card">
            {%- if section.settings.show_image and article.image -%}
              <a href="{{ article.url }}" class="blog-card__media">
                {%- render 'responsive-image',
                  image: article.image,
                  widths: '300,450,600',
                  sizes: '(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw',
                  loading: 'lazy',
                  class: 'blog-card__image'
                -%}
              </a>
            {%- endif -%}

            <div class="blog-card__info">
              {%- if section.settings.show_tags and article.tags.size > 0 -%}
                <div class="blog-card__tags">
                  {%- for tag in article.tags limit: 2 -%}
                    <span class="blog-card__tag text-overline">{{ tag }}</span>
                  {%- endfor -%}
                </div>
              {%- endif -%}

              <h2 class="blog-card__title text-heading-md">
                <a href="{{ article.url }}">{{ article.title }}</a>
              </h2>

              <p class="blog-card__excerpt text-body-md color-secondary">
                {{ article.excerpt_or_content | strip_html | truncate: 120 }}
              </p>

              {%- if section.settings.show_date -%}
                <time class="blog-card__date text-body-sm color-secondary" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                  {{ article.published_at | date: '%B %d, %Y' }}
                </time>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        {%- render 'pagination', paginate: paginate -%}
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>

<style>
  .blog-card__media {
    display: block;
    aspect-ratio: 16 / 10;
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: var(--space-4);
  }
  .blog-card__image { width: 100%; height: 100%; object-fit: cover; transition: transform var(--duration-slow) var(--ease-smooth); }
  .blog-card__media:hover .blog-card__image { transform: scale(1.03); }
  .blog-card__info { display: flex; flex-direction: column; gap: var(--space-2); }
  .blog-card__tags { display: flex; gap: var(--space-2); }
  .blog-card__tag { color: var(--interactive-accent); }
  .blog-card__title { margin: 0; }
  .blog-card__title a { color: inherit; }
  .blog-card__title a:hover { color: var(--interactive-primary-hover); }
  .blog-card__excerpt { margin: 0; }
</style>

{% schema %}
{
  "name": "Blog Posts",
  "tag": "section",
  "class": "section--main-blog",
  "limit": 1,
  "settings": [
    { "type": "range", "id": "articles_per_page", "label": "Articles per page", "min": 3, "max": 12, "default": 9 },
    { "type": "select", "id": "columns", "label": "Columns", "default": "3", "options": [{ "value": "2", "label": "2" }, { "value": "3", "label": "3" }] },
    { "type": "checkbox", "id": "show_image", "label": "Show featured image", "default": true },
    { "type": "checkbox", "id": "show_date", "label": "Show date", "default": true },
    { "type": "checkbox", "id": "show_tags", "label": "Show tags", "default": true }
  ]
}
{% endschema %}
