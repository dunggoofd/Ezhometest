{%- comment -%}
  EzHome — Main Cart Section (fallback for no-JS)
{%- endcomment -%}

<div class="main-cart section-spacing" data-section-id="{{ section.id }}">
  <div class="page-width">
    <h1 class="text-heading-2xl" style="margin-bottom: var(--space-6);">{{ 'cart.title' | t }}</h1>

    {%- if cart.item_count > 0 -%}
      {%- render 'free-shipping-bar', cart: cart -%}

      <form action="/cart" method="post" class="main-cart__form">
        <div class="main-cart__items">
          <div class="main-cart__header">
            <span class="text-body-sm color-secondary">Product</span>
            <span class="text-body-sm color-secondary">Quantity</span>
            <span class="text-body-sm color-secondary" style="text-align: right;">Total</span>
          </div>

          {%- for item in cart.items -%}
            {%- render 'cart-item', item: item -%}
          {%- endfor -%}
        </div>

        <div class="main-cart__footer">
          {%- if section.settings.enable_cart_note -%}
            <div class="main-cart__note form-field">
              <label class="form-label" for="cart-note">Order Notes</label>
              <textarea name="note" id="cart-note" class="form-textarea" rows="3" placeholder="Special instructions...">{{ cart.note }}</textarea>
            </div>
          {%- endif -%}

          <div class="main-cart__summary">
            <div class="main-cart__subtotal flex flex--between">
              <span class="text-heading-md">{{ 'cart.subtotal' | t }}</span>
              <span class="text-heading-md">{{ cart.total_price | money }}</span>
            </div>
            <p class="text-body-sm color-secondary">{{ 'cart.shipping_note' | t }}</p>

            <button type="submit" name="checkout" class="btn btn--primary btn--full btn--lg">
              {{ 'cart.checkout' | t }}
            </button>
          </div>
        </div>
      </form>
    {%- else -%}
      <div class="main-cart__empty" style="text-align: center; padding: var(--space-16) 0;">
        <p class="text-body-lg">{{ 'cart.empty' | t }}</p>
        <a href="/collections/all" class="btn btn--primary">{{ 'cart.continue_shopping' | t }}</a>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .main-cart__header { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: var(--space-4); padding-bottom: var(--space-3); border-bottom: 1px solid var(--border-secondary); margin-bottom: var(--space-4); }
  .main-cart__footer { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-8); margin-top: var(--space-8); padding-top: var(--space-6); border-top: 1px solid var(--border-secondary); }
  .main-cart__summary { display: flex; flex-direction: column; gap: var(--space-3); }

  @media (max-width: 768px) {
    .main-cart__header { display: none; }
    .main-cart__footer { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{
  "name": "Cart",
  "tag": "section",
  "class": "section--main-cart",
  "limit": 1,
  "settings": [
    { "type": "checkbox", "id": "enable_cart_note", "label": "Enable order notes", "default": true }
  ]
}
{% endschema %}
