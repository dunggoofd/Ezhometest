{%- comment -%}
  EzHome — Customer Addresses Section
{%- endcomment -%}

<div class="customer-addresses section-spacing">
  <div class="page-width content-width">
    <h1 class="text-heading-2xl" style="margin-bottom: var(--space-6);">{{ 'customer.addresses.title' | t }}</h1>

    <button class="btn btn--primary btn--sm" data-address-toggle style="margin-bottom: var(--space-6);">
      {{ 'customer.addresses.add_new' | t }}
    </button>

    {%- comment -%} New Address Form {%- endcomment -%}
    <div id="add-address" style="display: none; margin-bottom: var(--space-8);">
      {%- form 'customer_address', customer.new_address, class: 'customer-form__fields' -%}
        <h2 class="text-heading-lg">Add New Address</h2>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4);">
          <div class="form-field"><label class="form-label" for="address-first-name">First Name</label><input type="text" name="address[first_name]" id="address-first-name" class="form-input" autocomplete="given-name"></div>
          <div class="form-field"><label class="form-label" for="address-last-name">Last Name</label><input type="text" name="address[last_name]" id="address-last-name" class="form-input" autocomplete="family-name"></div>
        </div>
        <div class="form-field"><label class="form-label" for="address-address1">Address</label><input type="text" name="address[address1]" id="address-address1" class="form-input" autocomplete="address-line1"></div>
        <div class="form-field"><label class="form-label" for="address-address2">Apartment, suite, etc.</label><input type="text" name="address[address2]" id="address-address2" class="form-input" autocomplete="address-line2"></div>
        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: var(--space-4);">
          <div class="form-field"><label class="form-label" for="address-city">City</label><input type="text" name="address[city]" id="address-city" class="form-input" autocomplete="address-level2"></div>
          <div class="form-field"><label class="form-label" for="address-province">State / Province</label><input type="text" name="address[province]" id="address-province" class="form-input" autocomplete="address-level1"></div>
          <div class="form-field"><label class="form-label" for="address-zip">Zip / Postal</label><input type="text" name="address[zip]" id="address-zip" class="form-input" autocomplete="postal-code"></div>
        </div>
        <div class="form-field">
          <label class="form-label" for="address-country">Country</label>
          <select name="address[country]" id="address-country" class="form-select" autocomplete="country">{{ country_option_tags }}</select>
        </div>
        <div class="form-field"><label><input type="checkbox" name="address[default]" value="1"> Set as default address</label></div>
        <button type="submit" class="btn btn--primary">Save Address</button>
      {%- endform -%}
    </div>

    {%- comment -%} Existing Addresses {%- endcomment -%}
    <div class="customer-addresses__list" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: var(--space-4);">
      {%- for address in customer.addresses -%}
        <div class="customer-addresses__card" style="padding: var(--space-5); border: 1px solid var(--border-secondary); border-radius: var(--radius-lg);">
          {%- if address == customer.default_address -%}
            <span class="badge badge--new" style="margin-bottom: var(--space-2);">Default</span>
          {%- endif -%}
          <p class="text-body-md">{{ address | format_address }}</p>
          <div style="display: flex; gap: var(--space-2); margin-top: var(--space-3);">
            <a href="/account/addresses/{{ address.id }}" class="btn btn--ghost btn--sm">Edit</a>
            <button class="btn btn--ghost btn--sm" onclick="if(confirm('Delete this address?')) Shopify.postLink('/account/addresses/{{ address.id }}', { parameters: { _method: 'delete' } })">Delete</button>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .customer-form__fields { display: flex; flex-direction: column; gap: var(--space-4); }
</style>

<script>
  document.querySelector('[data-address-toggle]')?.addEventListener('click', () => {
    const form = document.getElementById('add-address');
    form.style.display = form.style.display === 'none' ? 'block' : 'none';
  });
</script>

{% schema %}
{
  "name": "Customer Addresses",
  "tag": "section",
  "class": "section--customer-addresses",
  "limit": 1,
  "settings": []
}
{% endschema %}
