{%- comment -%}
  EzHome — Assembly Steps Section
{%- endcomment -%}

<div class="assembly-steps section-spacing" data-section-id="{{ section.id }}">
  <div class="page-width content-width">
    {%- if section.settings.heading != blank -%}
      <div style="text-align: center; margin-bottom: var(--space-8);">
        {%- if section.settings.eyebrow != blank -%}
          <span class="text-overline color-accent">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="text-heading-2xl">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="assembly-steps__list">
      {%- for block in section.blocks -%}
        <div class="assembly-steps__step" {{ block.shopify_attributes }}>
          <div class="assembly-steps__number">
            <span class="text-heading-xl">{{ forloop.index }}</span>
          </div>
          <div class="assembly-steps__content">
            {%- if block.settings.image != blank -%}
              <div class="assembly-steps__image" style="aspect-ratio: 16/9; border-radius: var(--radius-lg); overflow: hidden; margin-bottom: var(--space-4);">
                <img
                  src="{{ block.settings.image | image_url: width: 700 }}"
                  alt="{{ block.settings.heading | escape }}"
                  loading="lazy"
                  style="width: 100%; height: 100%; object-fit: cover;"
                >
              </div>
            {%- endif -%}
            <h3 class="text-heading-lg">{{ block.settings.heading }}</h3>
            {%- if block.settings.text != blank -%}
              <p class="text-body-md color-secondary" style="margin-top: var(--space-2);">{{ block.settings.text }}</p>
            {%- endif -%}
            {%- if block.settings.time != blank -%}
              <span class="text-body-sm color-accent" style="margin-top: var(--space-1); display: inline-block;">⏱ {{ block.settings.time }}</span>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .assembly-steps__list { display: flex; flex-direction: column; gap: var(--space-10); }
  .assembly-steps__step { display: grid; grid-template-columns: 60px 1fr; gap: var(--space-6); align-items: start; }
  .assembly-steps__number { width: 60px; height: 60px; border-radius: var(--radius-full); background: var(--bg-accent); color: var(--color-white); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }

  @media (max-width: 768px) {
    .assembly-steps__step { grid-template-columns: 48px 1fr; gap: var(--space-4); }
    .assembly-steps__number { width: 48px; height: 48px; }
  }
</style>

{% schema %}
{
  "name": "Assembly Steps",
  "tag": "section",
  "class": "section--assembly-steps",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Step-by-Step" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Assembly in 3 Easy Steps" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "heading", "label": "Step title" },
        { "type": "textarea", "id": "text", "label": "Description" },
        { "type": "text", "id": "time", "label": "Time estimate" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Assembly Steps",
      "settings": { "heading": "Assembly in 3 Easy Steps" },
      "blocks": [
        { "type": "step", "settings": { "heading": "Unbox & Unroll", "text": "Remove the vacuum-sealed sofa from the box and cut the packaging. Watch it begin to expand immediately.", "time": "1 minute" } },
        { "type": "step", "settings": { "heading": "Click & Connect", "text": "Snap the modular pieces together using our tool-free connection system. No screws, no Allen keys.", "time": "5 minutes" } },
        { "type": "step", "settings": { "heading": "Fluff & Enjoy", "text": "Give the cushions a few fluffs and your sofa is ready. Full expansion takes 24-48 hours for peak comfort.", "time": "4 minutes" } }
      ]
    }
  ]
}
{% endschema %}
