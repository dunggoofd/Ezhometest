{%- comment -%}
  EzHome — Footer Section
  Link columns, newsletter, social, payment icons
{%- endcomment -%}

<footer class="footer" data-section-id="{{ section.id }}" role="contentinfo">
  <div class="footer__inner page-width">
    <div class="footer__grid">

      {%- comment -%} Link Columns & Newsletter Blocks {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}

          {%- when 'link_column' -%}
            <div class="footer__column" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h3 class="footer__heading text-body-md" style="font-weight: var(--weight-semibold); margin-bottom: var(--space-3);">
                  {{ block.settings.heading }}
                </h3>
              {%- endif -%}

              {%- assign menu = linklists[block.settings.menu] -%}
              {%- if menu != blank -%}
                <ul class="footer__links">
                  {%- for link in menu.links -%}
                    <li>
                      <a href="{{ link.url }}" class="footer__link">{{ link.title }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>

          {%- when 'newsletter' -%}
            <div class="footer__column footer__column--newsletter" {{ block.shopify_attributes }}>
              {%- render 'newsletter-form',
                heading: block.settings.heading,
                subtext: block.settings.subtext
              -%}

              <div style="margin-top: var(--space-4);">
                {%- render 'social-icons' -%}
              </div>
            </div>

        {%- endcase -%}
      {%- endfor -%}
    </div>

    {%- comment -%} Bottom Bar {%- endcomment -%}
    <div class="footer__bottom">
      <div class="footer__copyright text-body-sm color-secondary">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.
        {%- if section.settings.copyright_text != blank -%}
          {{ section.settings.copyright_text }}
        {%- else -%}
          All rights reserved.
        {%- endif -%}
      </div>

      {%- if section.settings.show_payment_icons -%}
        <div class="footer__payment">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag: class: 'footer__payment-icon' }}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--bg-secondary);
    padding-top: var(--space-16);
    padding-bottom: var(--space-8);
    margin-top: var(--space-20);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-8);
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--border-secondary);
  }

  .footer__column--newsletter {
    grid-column: span 1;
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer__link {
    font-size: var(--text-body-sm);
    color: var(--text-secondary);
    transition: color var(--duration-fast) var(--ease-default);
  }

  .footer__link:hover {
    color: var(--text-primary);
  }

  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-6);
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .footer__payment {
    display: flex;
    gap: var(--space-2);
    align-items: center;
    flex-wrap: wrap;
  }

  .footer__payment-icon {
    width: 38px;
    height: 24px;
    opacity: 0.6;
  }

  @media (max-width: 1024px) {
    .footer__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .footer {
      padding-top: var(--space-10);
      margin-top: var(--space-12);
    }

    .footer__grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .footer__bottom {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "class": "footer-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "info": "Leave blank for default"
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Link Column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Join The EzHome Family"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext",
          "default": "Get early access, assembly tips & exclusive deals."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "link_column", "settings": { "heading": "Shop" } },
        { "type": "link_column", "settings": { "heading": "Support" } },
        { "type": "link_column", "settings": { "heading": "Company" } },
        { "type": "newsletter" }
      ]
    }
  ]
}
{% endschema %}
