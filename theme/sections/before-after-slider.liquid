{%- comment -%}
  EzHome — Before/After Slider Section
  Interactive comparison of boxed vs assembled product
{%- endcomment -%}

<div class="before-after section-spacing" data-section-id="{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="before-after__header reveal">
        {%- if section.settings.eyebrow != blank -%}
          <span class="text-overline color-accent">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="text-heading-xl">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="before-after__container reveal" style="--reveal-delay: 1;">
      <div class="before-after__wrapper" data-before-after>
        {%- if section.settings.before_image != blank -%}
          <div class="before-after__image before-after__image--before">
            {%- render 'responsive-image',
              image: section.settings.before_image,
              widths: '600,900,1200',
              sizes: '(min-width: 1024px) 50vw, 100vw',
              loading: 'lazy'
            -%}
            <span class="before-after__label before-after__label--before">{{ section.settings.before_label | default: 'Before' }}</span>
          </div>
        {%- else -%}
          <div class="before-after__image before-after__image--before before-after__image--placeholder">
            {{ 'product-1' | placeholder_svg_tag }}
            <span class="before-after__label before-after__label--before">{{ section.settings.before_label | default: 'In the box' }}</span>
          </div>
        {%- endif -%}

        {%- if section.settings.after_image != blank -%}
          <div class="before-after__image before-after__image--after">
            {%- render 'responsive-image',
              image: section.settings.after_image,
              widths: '600,900,1200',
              sizes: '(min-width: 1024px) 50vw, 100vw',
              loading: 'lazy'
            -%}
            <span class="before-after__label before-after__label--after">{{ section.settings.after_label | default: 'After' }}</span>
          </div>
        {%- else -%}
          <div class="before-after__image before-after__image--after before-after__image--placeholder">
            {{ 'product-2' | placeholder_svg_tag }}
            <span class="before-after__label before-after__label--after">{{ section.settings.after_label | default: 'Fully assembled' }}</span>
          </div>
        {%- endif -%}

        <div class="before-after__slider" data-before-after-slider>
          <div class="before-after__handle">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M8 4l-6 8 6 8M16 4l6 8-6 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .before-after__header {
    text-align: center;
    margin-bottom: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .before-after__wrapper {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-xl);
    aspect-ratio: 16 / 9;
    cursor: ew-resize;
    user-select: none;
    -webkit-user-select: none;
  }

  .before-after__image {
    position: absolute;
    inset: 0;
  }

  .before-after__image img,
  .before-after__image svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .before-after__image--before {
    z-index: 1;
    clip-path: inset(0 50% 0 0);
  }

  .before-after__image--after {
    z-index: 0;
  }

  .before-after__image--placeholder {
    background-color: var(--bg-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .before-after__label {
    position: absolute;
    bottom: var(--space-4);
    padding: var(--space-1) var(--space-3);
    background-color: rgba(0, 0, 0, 0.7);
    color: white;
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    border-radius: var(--radius-full);
    z-index: 3;
  }

  .before-after__label--before {
    left: var(--space-4);
  }

  .before-after__label--after {
    right: var(--space-4);
  }

  .before-after__slider {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 4px;
    background-color: white;
    z-index: 2;
    transform: translateX(-50%);
    box-shadow: 0 0 8px rgba(0, 0, 0, 0.3);
  }

  .before-after__handle {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 48px;
    height: 48px;
    background-color: white;
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-md);
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .before-after__wrapper {
      aspect-ratio: 4 / 3;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('[data-before-after]').forEach(container => {
      const slider = container.querySelector('[data-before-after-slider]');
      const beforeImage = container.querySelector('.before-after__image--before');
      if (!slider || !beforeImage) return;

      let isDragging = false;

      function updatePosition(x) {
        const rect = container.getBoundingClientRect();
        let percentage = ((x - rect.left) / rect.width) * 100;
        percentage = Math.max(5, Math.min(95, percentage));
        slider.style.left = percentage + '%';
        beforeImage.style.clipPath = `inset(0 ${100 - percentage}% 0 0)`;
      }

      slider.addEventListener('mousedown', (e) => { isDragging = true; e.preventDefault(); });
      document.addEventListener('mouseup', () => { isDragging = false; });
      document.addEventListener('mousemove', (e) => { if (isDragging) updatePosition(e.clientX); });

      slider.addEventListener('touchstart', (e) => { isDragging = true; }, { passive: true });
      document.addEventListener('touchend', () => { isDragging = false; });
      document.addEventListener('touchmove', (e) => {
        if (isDragging) updatePosition(e.touches[0].clientX);
      }, { passive: true });
    });
  });
</script>

{% schema %}
{
  "name": "Before / After Slider",
  "tag": "section",
  "class": "section--before-after",
  "limit": 2,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "SEE THE TRANSFORMATION"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See The Transformation"
    },
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "Before image"
    },
    {
      "type": "text",
      "id": "before_label",
      "label": "Before label",
      "default": "In the box"
    },
    {
      "type": "image_picker",
      "id": "after_image",
      "label": "After image"
    },
    {
      "type": "text",
      "id": "after_label",
      "label": "After label",
      "default": "Fully assembled"
    }
  ],
  "presets": [
    {
      "name": "Before / After Slider",
      "category": "EzHome"
    }
  ]
}
{% endschema %}
