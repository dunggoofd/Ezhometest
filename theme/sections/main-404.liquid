{%- comment -%}
  EzHome — 404 Section
{%- endcomment -%}

<div class="main-404 section-spacing" data-section-id="{{ section.id }}">
  <div class="page-width" style="text-align: center;">
    <div style="padding: var(--space-12) 0;">
      <span class="text-display-xl" style="display: block; color: var(--text-tertiary); margin-bottom: var(--space-4);">404</span>
      <h1 class="text-heading-2xl">{{ section.settings.heading | default: 'Page Not Found' }}</h1>
      <p class="text-body-lg color-secondary" style="max-width: 480px; margin: var(--space-3) auto 0;">
        {{ section.settings.text | default: "The page you're looking for has moved or doesn't exist." }}
      </p>

      {%- if section.settings.show_search -%}
        <form action="{{ routes.search_url }}" method="get" role="search" style="max-width: 400px; margin: var(--space-6) auto;">
          <div style="display: flex; gap: var(--space-2);">
            <input type="search" name="q" placeholder="Search..." class="form-input" style="flex: 1;" aria-label="Search">
            <button type="submit" class="btn btn--primary">Search</button>
          </div>
        </form>
      {%- endif -%}

      <a href="{{ section.settings.cta_url | default: '/' }}" class="btn btn--secondary" style="margin-top: var(--space-4);">
        {{ section.settings.cta_text | default: 'Back To Home' }}
      </a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "404",
  "tag": "section",
  "class": "section--404",
  "limit": 1,
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Page Not Found" },
    { "type": "text", "id": "text", "label": "Text", "default": "The page you're looking for has moved or doesn't exist." },
    { "type": "checkbox", "id": "show_search", "label": "Show search", "default": true },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Back To Home" },
    { "type": "url", "id": "cta_url", "label": "Button link" }
  ]
}
{% endschema %}
