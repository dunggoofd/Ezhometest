{%- comment -%}
  EzHome — Customer Register Section
{%- endcomment -%}

<div class="customer-register section-spacing">
  <div class="page-width narrow-width">
    <div class="customer-form" style="max-width: 440px; margin: 0 auto;">
      <h1 class="text-heading-2xl" style="text-align: center; margin-bottom: var(--space-6);">{{ 'customer.register.title' | t }}</h1>

      {%- form 'create_customer', class: 'customer-form__fields' -%}
        {%- if form.errors -%}
          <div class="contact-form__errors">{{ form.errors | default_errors }}</div>
        {%- endif -%}

        <div class="form-field">
          <label class="form-label" for="register-first-name">First Name</label>
          <input type="text" name="customer[first_name]" id="register-first-name" class="form-input" required autocomplete="given-name">
        </div>
        <div class="form-field">
          <label class="form-label" for="register-last-name">Last Name</label>
          <input type="text" name="customer[last_name]" id="register-last-name" class="form-input" required autocomplete="family-name">
        </div>
        <div class="form-field">
          <label class="form-label" for="register-email">Email</label>
          <input type="email" name="customer[email]" id="register-email" class="form-input" required autocomplete="email">
        </div>
        <div class="form-field">
          <label class="form-label" for="register-password">Password</label>
          <input type="password" name="customer[password]" id="register-password" class="form-input" required autocomplete="new-password">
        </div>

        <button type="submit" class="btn btn--primary btn--full btn--lg">{{ 'customer.register.submit' | t }}</button>

        <p style="text-align: center;" class="text-body-sm color-secondary">
          Already have an account? <a href="/account/login">Sign in</a>
        </p>
      {%- endform -%}
    </div>
  </div>
</div>

<style>
  .customer-form__fields { display: flex; flex-direction: column; gap: var(--space-4); }
</style>

{% schema %}
{
  "name": "Customer Register",
  "tag": "section",
  "class": "section--customer-register",
  "limit": 1,
  "settings": []
}
{% endschema %}
