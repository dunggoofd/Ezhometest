{%- comment -%}
  EzHome — Activate Account Section
{%- endcomment -%}

<div class="customer-activate section-spacing">
  <div class="page-width narrow-width">
    <div class="customer-form" style="max-width: 440px; margin: 0 auto;">
      <h1 class="text-heading-2xl" style="text-align: center; margin-bottom: var(--space-4);">Activate Your Account</h1>
      <p class="text-body-md color-secondary" style="text-align: center; margin-bottom: var(--space-6);">Create a password to activate your account.</p>

      {%- form 'activate_customer_password', class: 'customer-form__fields' -%}
        {%- if form.errors -%}
          <div class="contact-form__errors">{{ form.errors | default_errors }}</div>
        {%- endif -%}

        <div class="form-field">
          <label class="form-label" for="activate-password">Password</label>
          <input type="password" name="customer[password]" id="activate-password" class="form-input" required autocomplete="new-password">
        </div>
        <div class="form-field">
          <label class="form-label" for="activate-password-confirm">Confirm Password</label>
          <input type="password" name="customer[password_confirmation]" id="activate-password-confirm" class="form-input" required autocomplete="new-password">
        </div>

        <button type="submit" class="btn btn--primary btn--full btn--lg">Activate Account</button>
        <p style="text-align: center;"><a href="#" onclick="document.querySelector('[name=decline]').click(); return false;" class="text-body-sm color-secondary">Decline invitation</a></p>
        <button type="submit" name="decline" style="display: none;">Decline</button>
      {%- endform -%}
    </div>
  </div>
</div>

<style>
  .customer-form__fields { display: flex; flex-direction: column; gap: var(--space-4); }
</style>

{% schema %}
{
  "name": "Activate Account",
  "tag": "section",
  "class": "section--customer-activate",
  "limit": 1,
  "settings": []
}
{% endschema %}
