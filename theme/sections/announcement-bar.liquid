{%- comment -%}
  EzHome — Announcement Bar Section
  Rotating announcement messages with dismiss
{%- endcomment -%}

{%- if section.blocks.size > 0 -%}
  <announcement-bar
    class="announcement-bar color-inverse"
    data-section-id="{{ section.id }}"
    data-auto-rotate="{{ section.settings.auto_rotate }}"
    data-rotate-speed="{{ section.settings.rotate_speed | times: 1000 }}"
    role="region"
    aria-label="Announcement"
  >
    <div class="announcement-bar__inner page-width">
      <div class="announcement-bar__messages">
        {%- for block in section.blocks -%}
          <div
            class="announcement-bar__message{% if forloop.first %} is-active{% endif %}"
            data-announcement-message
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="announcement-bar__link">
                {{ block.settings.text }}
              </a>
            {%- else -%}
              <p class="announcement-bar__text">{{ block.settings.text }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      {%- if section.settings.show_dismiss -%}
        <button class="announcement-bar__dismiss" data-announcement-dismiss aria-label="Dismiss announcement">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M12 4L4 12M4 4l8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      {%- endif -%}
    </div>
  </announcement-bar>
{%- endif -%}

<style>
  .announcement-bar {
    background-color: var(--bg-inverse);
    color: var(--text-inverse);
    padding-block: var(--space-2);
    font-size: var(--text-body-sm);
    line-height: var(--text-body-sm-leading);
    text-align: center;
    position: relative;
    z-index: var(--z-sticky);
  }

  .announcement-bar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
  }

  .announcement-bar__messages {
    position: relative;
    flex: 1;
    min-height: 20px;
  }

  .announcement-bar__message {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--duration-slow) var(--ease-default);
    pointer-events: none;
  }

  .announcement-bar__message.is-active {
    position: relative;
    opacity: 1;
    pointer-events: auto;
  }

  .announcement-bar__text,
  .announcement-bar__link {
    font-weight: var(--weight-medium);
    margin: 0;
  }

  .announcement-bar__link {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .announcement-bar__link:hover {
    color: inherit;
    opacity: 0.8;
  }

  .announcement-bar__dismiss {
    flex-shrink: 0;
    color: inherit;
    opacity: 0.7;
    padding: var(--space-1);
    transition: opacity var(--duration-fast) var(--ease-default);
  }

  .announcement-bar__dismiss:hover {
    opacity: 1;
  }
</style>

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "section",
  "class": "announcement-bar-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate messages",
      "default": true
    },
    {
      "type": "range",
      "id": "rotate_speed",
      "label": "Rotation speed (seconds)",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "show_dismiss",
      "label": "Show dismiss button",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free delivery on all orders this week"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text": "Free delivery on all orders this week — ends Sunday"
          }
        }
      ]
    }
  ]
}
{% endschema %}
