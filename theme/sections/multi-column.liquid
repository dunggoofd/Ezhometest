{%- comment -%}
  EzHome — Multi-Column Section
  Flexible icon + text columns (for contact info, features, etc.)
{%- endcomment -%}

<div class="multi-column section-spacing" data-section-id="{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="multi-column__heading text-heading-xl" style="margin-bottom: var(--space-8);">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="multi-column__grid" style="--cols: {{ section.blocks.size | at_most: 4 }};">
      {%- for block in section.blocks -%}
        <div class="multi-column__item" {{ block.shopify_attributes }}>
          {%- if block.settings.title != blank -%}
            <h3 class="text-heading-sm">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p class="text-body-md color-secondary">{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .multi-column__grid {
    display: grid;
    grid-template-columns: repeat(var(--cols, 3), 1fr);
    gap: var(--space-8);
  }
  .multi-column__item h3 { margin: 0 0 var(--space-2); }
  .multi-column__item p { margin: 0; }

  @media (max-width: 768px) {
    .multi-column__grid { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{
  "name": "Multi-Column",
  "tag": "section",
  "class": "section--multi-column",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Column Title" },
        { "type": "text", "id": "text", "label": "Text", "default": "Column description text" }
      ]
    }
  ],
  "presets": [{ "name": "Multi-Column", "category": "EzHome" }]
}
{% endschema %}
