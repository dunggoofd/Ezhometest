{%- comment -%}
  EzHome — Hero Banner Section
  Full-width hero with heading, subheading, CTAs, and social proof pill
{%- endcomment -%}

<div class="hero-banner{% if section.settings.full_height %} hero-banner--full{% endif %}" data-section-id="{{ section.id }}">
  {%- if section.settings.background_image != blank -%}
    <div class="hero-banner__media">
      {%- render 'responsive-image',
        image: section.settings.background_image,
        widths: '600,900,1200,1800,2400',
        sizes: '100vw',
        loading: 'eager',
        class: 'hero-banner__image'
      -%}
      <div class="hero-banner__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
    </div>
  {%- else -%}
    <div class="hero-banner__media hero-banner__media--placeholder" style="background-color: var(--bg-secondary);"></div>
  {%- endif -%}

  <div class="hero-banner__content page-width">
    {%- if section.settings.social_proof_text != blank -%}
      <div class="hero-banner__badge reveal">
        <span class="hero-banner__badge-text">{{ section.settings.social_proof_text }}</span>
      </div>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="hero-banner__heading text-display-xl reveal" style="--reveal-delay: 1;">
        {{ section.settings.heading }}
      </h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="hero-banner__subheading text-body-lg reveal" style="--reveal-delay: 2;">
        {{ section.settings.subheading }}
      </p>
    {%- endif -%}

    <div class="hero-banner__actions reveal" style="--reveal-delay: 3;">
      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="btn btn--primary btn--lg">
          {{ section.settings.cta_text }}
        </a>
      {%- endif -%}

      {%- if section.settings.cta_secondary_text != blank -%}
        <a href="{{ section.settings.cta_secondary_url | default: '#' }}" class="btn btn--ghost btn--lg">
          {{ section.settings.cta_secondary_text }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  .hero-banner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 75vh;
    overflow: hidden;
  }

  .hero-banner--full {
    min-height: 100vh;
  }

  .hero-banner__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-banner__media--placeholder {
    background: linear-gradient(135deg, var(--color-cream-100) 0%, var(--color-cream-200) 100%);
  }

  .hero-banner__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-banner__overlay {
    position: absolute;
    inset: 0;
    background-color: var(--color-ink-950);
  }

  .hero-banner__content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding-block: var(--space-16);
    max-width: 780px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
  }

  .hero-banner__badge {
    display: inline-flex;
    align-items: center;
    padding: var(--space-2) var(--space-4);
    background-color: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(8px);
    border-radius: var(--radius-full);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    color: var(--text-primary);
  }

  .hero-banner__heading {
    margin: 0;
  }

  .hero-banner__subheading {
    color: var(--text-secondary);
    max-width: 540px;
    margin: 0;
  }

  .hero-banner__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
    margin-top: var(--space-2);
  }

  @media (max-width: 768px) {
    .hero-banner {
      min-height: 60vh;
    }

    .hero-banner--full {
      min-height: 90vh;
    }

    .hero-banner__content {
      padding-block: var(--space-10);
    }
  }
</style>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "hero-banner-section",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sofa In. Stress Out. Instantly."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "A premium sofa that compresses to fit through any door — and looks like it never had to."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Primary button text",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "Secondary button text",
      "default": "See How It Works →"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "social_proof_text",
      "label": "Social proof badge",
      "default": "★ 4.9 · 2,400+ Happy Homes"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 20,
      "unit": "%"
    },
    {
      "type": "checkbox",
      "id": "full_height",
      "label": "Full viewport height",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "category": "EzHome"
    }
  ]
}
{% endschema %}
