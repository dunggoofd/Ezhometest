{%- comment -%}
  EzHome — Instagram Feed Section
  User-generated content grid with #MyEzHome tag
{%- endcomment -%}

<div class="instagram-feed section-spacing" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="instagram-feed__header reveal">
      {%- if section.settings.heading != blank -%}
        <h2 class="text-heading-xl">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <p class="text-body-lg color-secondary">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>

    <div class="instagram-feed__grid reveal" style="--reveal-delay: 1;">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <a
            href="{{ block.settings.link | default: '#' }}"
            class="instagram-feed__item"
            target="_blank"
            rel="noopener noreferrer"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.image != blank -%}
              {%- render 'responsive-image',
                image: block.settings.image,
                widths: '200,300,400',
                sizes: '(min-width: 1024px) 16vw, (min-width: 768px) 25vw, 33vw',
                loading: 'lazy',
                class: 'instagram-feed__image'
              -%}
            {%- else -%}
              <div class="instagram-feed__placeholder">
                {{ 'lifestyle-1' | placeholder_svg_tag }}
              </div>
            {%- endif -%}
            <div class="instagram-feed__overlay">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor"/>
              </svg>
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..6) -%}
          <div class="instagram-feed__item instagram-feed__item--placeholder">
            <div class="instagram-feed__placeholder">
              {{ 'lifestyle-1' | placeholder_svg_tag }}
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.instagram_url != blank -%}
      <div class="instagram-feed__cta reveal" style="--reveal-delay: 2;">
        <a href="{{ section.settings.instagram_url }}" class="btn btn--ghost" target="_blank" rel="noopener noreferrer">
          Follow us on Instagram
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 12L12 4M12 4H5M12 4v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .instagram-feed__header {
    text-align: center;
    margin-bottom: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .instagram-feed__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: var(--space-3);
  }

  .instagram-feed__item {
    position: relative;
    aspect-ratio: 1;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .instagram-feed__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-smooth);
  }

  .instagram-feed__item:hover .instagram-feed__image {
    transform: scale(1.05);
  }

  .instagram-feed__placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--bg-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .instagram-feed__placeholder svg {
    width: 100%;
    height: 100%;
  }

  .instagram-feed__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    opacity: 0;
    transition: opacity var(--duration-fast) var(--ease-default);
  }

  .instagram-feed__item:hover .instagram-feed__overlay {
    opacity: 1;
  }

  .instagram-feed__cta {
    text-align: center;
    margin-top: var(--space-6);
  }

  @media (max-width: 1024px) {
    .instagram-feed__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 480px) {
    .instagram-feed__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-2);
    }
  }
</style>

{% schema %}
{
  "name": "Instagram Feed",
  "tag": "section",
  "class": "section--instagram-feed",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "#MyEzHome"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Share your setup. Tag us for a chance to be featured."
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram profile URL"
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Post",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Post link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram Feed",
      "category": "EzHome"
    }
  ]
}
{% endschema %}
