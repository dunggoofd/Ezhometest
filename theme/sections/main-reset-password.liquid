{%- comment -%}
  EzHome — Password Reset Section
{%- endcomment -%}

<div class="customer-reset section-spacing">
  <div class="page-width narrow-width">
    <div class="customer-form" style="max-width: 440px; margin: 0 auto;">
      <h1 class="text-heading-2xl" style="text-align: center; margin-bottom: var(--space-4);">Reset Your Password</h1>
      <p class="text-body-md color-secondary" style="text-align: center; margin-bottom: var(--space-6);">Enter a new password.</p>

      {%- form 'reset_customer_password', class: 'customer-form__fields' -%}
        {%- if form.errors -%}
          <div class="contact-form__errors">{{ form.errors | default_errors }}</div>
        {%- endif -%}

        <div class="form-field">
          <label class="form-label" for="reset-password">New Password</label>
          <input type="password" name="customer[password]" id="reset-password" class="form-input" required autocomplete="new-password">
        </div>
        <div class="form-field">
          <label class="form-label" for="reset-password-confirm">Confirm New Password</label>
          <input type="password" name="customer[password_confirmation]" id="reset-password-confirm" class="form-input" required autocomplete="new-password">
        </div>

        <button type="submit" class="btn btn--primary btn--full btn--lg">Reset Password</button>
      {%- endform -%}
    </div>
  </div>
</div>

<style>
  .customer-form__fields { display: flex; flex-direction: column; gap: var(--space-4); }
</style>

{% schema %}
{
  "name": "Reset Password",
  "tag": "section",
  "class": "section--customer-reset",
  "limit": 1,
  "settings": []
}
{% endschema %}
