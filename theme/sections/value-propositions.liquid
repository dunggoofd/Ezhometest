{%- comment -%}
  EzHome — Value Propositions Section
  Icon + title + text grid (4 columns)
{%- endcomment -%}

<div class="value-props section-spacing" data-section-id="{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="value-props__header reveal">
        <h2 class="value-props__heading text-heading-xl">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="value-props__grid">
        {%- for block in section.blocks -%}
          <div class="value-props__item reveal" style="--reveal-delay: {{ forloop.index }};" {{ block.shopify_attributes }}>
            <div class="value-props__icon">
              {%- case block.settings.icon -%}
                {%- when 'box' -%}
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M3.27 6.96L12 12.01l8.73-5.05M12 22.08V12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {%- when 'clock' -%}
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M12 6v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {%- when 'truck' -%}
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M1 3h15v13H1z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M16 8h4l3 4v5h-7V8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><circle cx="5.5" cy="18.5" r="2.5" stroke="currentColor" stroke-width="1.5"/><circle cx="18.5" cy="18.5" r="2.5" stroke="currentColor" stroke-width="1.5"/></svg>
                {%- when 'shield' -%}
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {%- when 'heart' -%}
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
                {%- when 'star' -%}
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
                {%- else -%}
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {%- endcase -%}
            </div>
            <h3 class="value-props__title text-heading-sm">{{ block.settings.title }}</h3>
            <p class="value-props__text text-body-md color-secondary">{{ block.settings.text }}</p>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .value-props__header {
    text-align: center;
    margin-bottom: var(--space-10);
  }

  .value-props__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-8);
  }

  .value-props__item {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .value-props__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    border-radius: var(--radius-lg);
    background-color: var(--color-sage-50);
    color: var(--color-sage-700);
  }

  .value-props__title {
    margin: 0;
  }

  .value-props__text {
    margin: 0;
    max-width: 240px;
  }

  @media (max-width: 1024px) {
    .value-props__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .value-props__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-5);
    }

    .value-props__icon {
      width: 48px;
      height: 48px;
    }

    .value-props__icon svg {
      width: 24px;
      height: 24px;
    }
  }
</style>

{% schema %}
{
  "name": "Value Propositions",
  "tag": "section",
  "class": "section--value-props",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why EzHome?"
    }
  ],
  "blocks": [
    {
      "type": "value_prop",
      "name": "Value Prop",
      "limit": 6,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "box",
          "options": [
            { "value": "box", "label": "Box" },
            { "value": "clock", "label": "Clock" },
            { "value": "truck", "label": "Truck" },
            { "value": "shield", "label": "Shield" },
            { "value": "heart", "label": "Heart" },
            { "value": "star", "label": "Star" }
          ]
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "Feature description text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Value Propositions",
      "category": "EzHome",
      "blocks": [
        { "type": "value_prop", "settings": { "icon": "box", "title": "Fits In Your Car", "text": "Compressed to 1/5th the size" }},
        { "type": "value_prop", "settings": { "icon": "clock", "title": "10-Min Setup", "text": "No tools. No stress." }},
        { "type": "value_prop", "settings": { "icon": "truck", "title": "Free Shipping", "text": "Delivered to your door" }},
        { "type": "value_prop", "settings": { "icon": "shield", "title": "5-Year Warranty", "text": "Built to last" }}
      ]
    }
  ]
}
{% endschema %}
