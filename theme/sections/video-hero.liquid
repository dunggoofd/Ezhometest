{%- comment -%}
  EzHome — Video Hero Section (for Assembly page)
{%- endcomment -%}

<div class="video-hero section-spacing" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="video-hero__inner" style="text-align: center;">
      {%- if section.settings.eyebrow != blank -%}
        <span class="text-overline color-accent">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h1 class="text-heading-3xl">{{ section.settings.heading }}</h1>
      {%- if section.settings.text != blank -%}
        <p class="text-body-lg color-secondary" style="max-width: 640px; margin: var(--space-3) auto var(--space-6);">{{ section.settings.text }}</p>
      {%- endif -%}

      {%- if section.settings.video_url != blank -%}
        <div class="video-hero__media" style="aspect-ratio: 16/9; border-radius: var(--radius-lg); overflow: hidden; max-width: 800px; margin: 0 auto;">
          {%- if section.settings.video_url contains 'youtube' or section.settings.video_url contains 'youtu.be' -%}
            {%- assign video_id = section.settings.video_url | split: 'v=' | last | split: '&' | first -%}
            {%- if section.settings.video_url contains 'youtu.be' -%}
              {%- assign video_id = section.settings.video_url | split: 'youtu.be/' | last | split: '?' | first -%}
            {%- endif -%}
            <iframe src="https://www.youtube.com/embed/{{ video_id }}" width="800" height="450" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen style="width: 100%; height: 100%;"></iframe>
          {%- elsif section.settings.video_url contains 'vimeo' -%}
            {%- assign vimeo_id = section.settings.video_url | split: 'vimeo.com/' | last | split: '?' | first -%}
            <iframe src="https://player.vimeo.com/video/{{ vimeo_id }}" width="800" height="450" frameborder="0" allow="autoplay; fullscreen" allowfullscreen style="width: 100%; height: 100%;"></iframe>
          {%- else -%}
            <video src="{{ section.settings.video_url }}" controls playsinline style="width: 100%; height: 100%; object-fit: cover;"></video>
          {%- endif -%}
        </div>
      {%- elsif section.settings.cover_image != blank -%}
        <div class="video-hero__media" style="aspect-ratio: 16/9; border-radius: var(--radius-lg); overflow: hidden; max-width: 800px; margin: 0 auto;">
          <img
            src="{{ section.settings.cover_image | image_url: width: 1200 }}"
            alt="{{ section.settings.cover_image.alt | escape }}"
            loading="lazy"
            style="width: 100%; height: 100%; object-fit: cover;"
          >
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Video Hero",
  "tag": "section",
  "class": "section--video-hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Assembly Guide" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "10 Minutes. Zero Tools. Seriously." },
    { "type": "textarea", "id": "text", "label": "Description" },
    { "type": "text", "id": "video_url", "label": "Video URL", "info": "YouTube, Vimeo, or direct video URL" },
    { "type": "image_picker", "id": "cover_image", "label": "Cover image (fallback)" }
  ],
  "presets": [
    {
      "name": "Video Hero",
      "settings": {
        "eyebrow": "Assembly Guide",
        "heading": "10 Minutes. Zero Tools. Seriously."
      }
    }
  ]
}
{% endschema %}
