{%- comment -%}
  EzHome — Image with Text Section
  Flexible side-by-side layout for CTAs, assembly, about, etc.
{%- endcomment -%}

<div class="image-text section-spacing" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="image-text__grid{% if section.settings.image_position == 'right' %} image-text__grid--reversed{% endif %}">
      <div class="image-text__media reveal">
        {%- if section.settings.image != blank -%}
          {%- render 'responsive-image',
            image: section.settings.image,
            widths: '400,600,800,1000',
            sizes: '(min-width: 1024px) 50vw, 100vw',
            loading: 'lazy',
            class: 'image-text__image'
          -%}
        {%- elsif section.settings.video_url != blank -%}
          <div class="image-text__video">
            {%- if section.settings.video_url contains 'youtube' or section.settings.video_url contains 'youtu.be' -%}
              <iframe
                src="{{ section.settings.video_url | replace: 'watch?v=', 'embed/' }}"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
                title="{{ section.settings.heading }}"
              ></iframe>
            {%- endif -%}
          </div>
        {%- else -%}
          <div class="image-text__placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag }}
          </div>
        {%- endif -%}
      </div>

      <div class="image-text__content reveal" style="--reveal-delay: 1;">
        {%- if section.settings.eyebrow != blank -%}
          <span class="text-overline color-accent">{{ section.settings.eyebrow }}</span>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="image-text__heading text-heading-xl">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="image-text__body text-body-lg color-secondary rte">
            {{ section.settings.text }}
          </div>
        {%- endif -%}

        {%- if section.settings.cta_text != blank -%}
          <div class="image-text__cta">
            <a href="{{ section.settings.cta_url | default: '#' }}" class="btn btn--primary">
              {{ section.settings.cta_text }}
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<style>
  .image-text__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-10);
    align-items: center;
  }

  .image-text__grid--reversed {
    direction: rtl;
  }

  .image-text__grid--reversed > * {
    direction: ltr;
  }

  .image-text__image {
    width: 100%;
    height: auto;
    border-radius: var(--radius-xl);
    object-fit: cover;
  }

  .image-text__video {
    position: relative;
    padding-bottom: 56.25%;
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .image-text__video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .image-text__placeholder {
    aspect-ratio: 1;
    background-color: var(--bg-secondary);
    border-radius: var(--radius-xl);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .image-text__placeholder svg {
    width: 100%;
    height: 100%;
  }

  .image-text__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .image-text__heading {
    margin: 0;
  }

  .image-text__body {
    max-width: 500px;
  }

  .image-text__body p {
    margin: 0;
  }

  .image-text__cta {
    margin-top: var(--space-2);
  }

  @media (max-width: 768px) {
    .image-text__grid,
    .image-text__grid--reversed {
      grid-template-columns: 1fr;
      direction: ltr;
      gap: var(--space-6);
    }
  }
</style>

{% schema %}
{
  "name": "Image with Text",
  "tag": "section",
  "class": "section--image-text",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "10 Minutes. Zero Tools."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Watch how easy it is to set up your EzHome sofa.</p>"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Watch Video"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (YouTube)",
      "info": "Used if no image is set"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image with Text",
      "category": "EzHome"
    }
  ]
}
{% endschema %}
