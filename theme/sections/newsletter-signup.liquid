{%- comment -%}
  EzHome — Newsletter Signup Section
  Email subscription with heading, subtext, and Shopify customer form
{%- endcomment -%}

<div class="newsletter-section section-spacing" data-section-id="{{ section.id }}" style="background-color: var(--bg-secondary);">
  <div class="newsletter-section__inner page-width">
    <div class="newsletter-section__content reveal">
      {%- if section.settings.heading != blank -%}
        <h2 class="newsletter-section__heading text-heading-xl">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.subtext != blank -%}
        <p class="newsletter-section__subtext text-body-lg color-secondary">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>

    <div class="newsletter-section__form reveal" style="--reveal-delay: 1;">
      {%- form 'customer', class: 'newsletter-section__form-inner' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input type="hidden" name="contact[accepts_marketing]" value="true">

        {%- if form.posted_successfully? -%}
          <p class="newsletter-section__success text-body-md">
            🎉 Thanks for subscribing! Check your inbox for a welcome surprise.
          </p>
        {%- endif -%}

        {%- if form.errors -%}
          <p class="newsletter-section__error text-body-sm">
            {{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}
          </p>
        {%- endif -%}

        <div class="newsletter-section__field">
          <input
            type="email"
            name="contact[email]"
            placeholder="{{ section.settings.placeholder | default: 'Enter your email' }}"
            required
            autocomplete="email"
            class="form-input newsletter-section__input"
            aria-label="Email address"
          >
          <button type="submit" class="btn btn--primary newsletter-section__submit">
            {{ section.settings.button_text | default: 'Subscribe' }}
          </button>
        </div>

        {%- if section.settings.disclaimer != blank -%}
          <p class="newsletter-section__disclaimer text-body-xs color-secondary">
            {{ section.settings.disclaimer }}
          </p>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</div>

<style>
  .newsletter-section {
    padding-block: var(--space-16);
  }

  .newsletter-section__inner {
    max-width: 640px;
    margin-inline: auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .newsletter-section__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .newsletter-section__heading {
    margin: 0;
  }

  .newsletter-section__subtext {
    margin: 0;
  }

  .newsletter-section__form-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: center;
  }

  .newsletter-section__field {
    display: flex;
    gap: var(--space-2);
    width: 100%;
    max-width: 480px;
  }

  .newsletter-section__input {
    flex: 1;
    min-width: 0;
  }

  .newsletter-section__submit {
    flex-shrink: 0;
  }

  .newsletter-section__success {
    color: var(--status-success);
    margin: 0;
  }

  .newsletter-section__error {
    color: var(--status-error);
    margin: 0;
  }

  .newsletter-section__disclaimer {
    margin: 0;
    opacity: 0.7;
  }

  @media (max-width: 480px) {
    .newsletter-section__field {
      flex-direction: column;
    }
  }
</style>

{% schema %}
{
  "name": "Newsletter Signup",
  "tag": "section",
  "class": "section--newsletter-signup",
  "limit": 2,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join The EzHome Family"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Get early access, assembly tips & exclusive deals."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer text",
      "default": "No spam. Unsubscribe anytime. We respect your inbox."
    }
  ],
  "presets": [
    {
      "name": "Newsletter Signup",
      "category": "EzHome"
    }
  ]
}
{% endschema %}
